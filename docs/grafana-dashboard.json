{
  "title": "ProcessIQ Observabilite",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Documents completes",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(documents_generated_total{status=\"completed\"})",
          "legendFormat": "completed"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Documents en echec",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(documents_generated_total{status=\"failed\"})",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Debit documents/s",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(documents_generated_total{status=\"completed\"}[1m]))",
          "legendFormat": "docs/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Taille de file",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "queue_size{state=\"waiting\"}",
          "legendFormat": "waiting"
        },
        {
          "expr": "queue_size{state=\"active\"}",
          "legendFormat": "active"
        },
        {
          "expr": "queue_size{state=\"failed\"}",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Duree batch p95",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(batch_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 batch duration"
        }
      ]
    }
  ]
}
