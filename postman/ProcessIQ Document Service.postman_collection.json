{
  "info": {
    "_postman_id": "8a1f8fb0-7b3a-4ef6-a84f-7d6984b8b555",
    "name": "ProcessIQ Document Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection Postman pour tester les endpoints principaux de l'API."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "batchId",
      "value": ""
    },
    {
      "key": "documentId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health global",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Health API",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Metrics",
      "item": [
        {
          "name": "Metrics Prometheus",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/metrics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "metrics"
              ]
            }
          }
        },
        {
          "name": "Metrics JSON",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/metrics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "metrics"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Documentation",
      "item": [
        {
          "name": "OpenAPI JSON",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/openapi.json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "openapi.json"
              ]
            }
          }
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/docs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "docs"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Creer un batch",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Le batch est accepte', function () {",
                  "  pm.response.to.have.status(202);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data.batchId) {",
                  "  pm.collectionVariables.set('batchId', data.batchId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userIds\": [\"user-1\", \"user-2\", \"user-3\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/documents/batch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "documents",
                "batch"
              ]
            }
          }
        },
        {
          "name": "Suivre un batch",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Le statut du batch est accessible', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (Array.isArray(data.documents) && data.documents.length > 0 && data.documents[0].documentId) {",
                  "  pm.collectionVariables.set('documentId', data.documents[0].documentId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/documents/batch/{{batchId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "documents",
                "batch",
                "{{batchId}}"
              ]
            }
          }
        },
        {
          "name": "Telecharger un document",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/documents/{{documentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "documents",
                "{{documentId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
